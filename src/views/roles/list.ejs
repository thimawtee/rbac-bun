<% include ../layouts/header %>

<h1 class="text-2xl font-bold mb-4">Roles</h1>

<a href="/roles/create" class="bg-green-500 text-white px-4 py-2 rounded">
  + Add Role
</a>

<table class="w-full mt-4 bg-white shadow">
  <tr class="bg-gray-200">
    <th>ID</th>
    <th>Name</th>
  </tr>

  <% roles.forEach(r => { %>
    <tr>
      <td><%= r.id %></td>
      <td><%= r.name %></td>
    </tr>
  <% }) %>
</table>

<% include ../layouts/footer %>