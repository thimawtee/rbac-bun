<aside class="w-64 bg-gray-900 text-white min-h-screen p-4">

  <h2 class="text-xl font-bold mb-6">RBAC System</h2>

  <nav class="space-y-2">

    <!-- USERS (SEMUA ROLE BOLEH LIHAT) -->
    <a href="/users"
       class="block p-2 rounded hover:bg-gray-700">
      Users
    </a>

    <!-- ROLES (HANYA ADMIN) -->
    <% if (user && user.role_id === 1) { %>
      <a href="/roles"
         class="block p-2 rounded hover:bg-gray-700">
        Roles
      </a>
    <% } %>

    <!-- PERMISSIONS (HANYA ADMIN) -->
    <% if (user && user.role_id === 1) { %>
      <a href="/permissions"
         class="block p-2 rounded hover:bg-gray-700">
        Permissions
      </a>
    <% } %>

    <!-- LOGOUT -->
    <a href="/logout"
       class="block p-2 rounded bg-red-600 hover:bg-red-700 mt-4">
      Logout
    </a>

  </nav>

</aside>