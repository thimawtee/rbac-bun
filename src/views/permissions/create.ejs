<% include ../layouts/header %>

<h1 class="text-2xl font-bold mb-4">Create Permission</h1>

<form method="POST" action="/permissions" class="space-y-4">

  <input name="name" placeholder="Permission name"
    class="border p-2 w-full"/>

  <input name="resource" placeholder="Resource"
    class="border p-2 w-full"/>

  <input name="action" placeholder="Action"
    class="border p-2 w-full"/>

  <button class="bg-blue-500 text-white px-4 py-2 rounded">
    Save
  </button>

</form>

<% include ../layouts/footer %>